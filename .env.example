# Environment variables for mini-claude-cli
# Copy this file to .env and fill in your credentials

# Auth token (required) - either this or ANTHROPIC_AUTH_TOKEN
MINI_CLAUDE_AUTH_TOKEN=your-auth-token-here

# Optional: API key (if using API key auth instead of bearer token)
# MINI_CLAUDE_API_KEY=your-api-key-here

# Optional: Base URL (overrides config file)
# MINI_CLAUDE_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# Optional: Model (overrides config file)
# MINI_CLAUDE_MODEL=qwen3.5-plus

# Optional: Log file path
# MINI_CLAUDE_LOG=/tmp/mini-claude-cli.log
